{
  "name": "@jorcleme/cisco-icons-core",
  "version": "0.1.0",
  "type": "module",
  "description": "Framework-agnostic SVG icon library based on Phosphor Icons + Cisco branded icons",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jorcleme/cisco-icons-core.git"
  },
  "homepage": "https://github.com/jorcleme/cisco-icons-core#readme",
  "bugs": {
    "url": "https://github.com/jorcleme/cisco-icons-core/issues"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./icons.json": "./dist/icons.json",
    "./cisco/regular/*.svg": {
      "import": "./dist/cisco/regular/*.svg.js",
      "require": "./dist/cisco/regular/*.svg.cjs",
      "types": "./dist/cisco/regular/*.svg.d.ts"
    },
    "./phosphor/bold/*.svg": {
      "import": "./dist/phosphor/bold/*.svg.js",
      "require": "./dist/phosphor/bold/*.svg.cjs",
      "types": "./dist/phosphor/bold/*.svg.d.ts"
    },
    "./phosphor/duotone/*.svg": {
      "import": "./dist/phosphor/duotone/*.svg.js",
      "require": "./dist/phosphor/duotone/*.svg.cjs",
      "types": "./dist/phosphor/duotone/*.svg.d.ts"
    },
    "./phosphor/fill/*.svg": {
      "import": "./dist/phosphor/fill/*.svg.js",
      "require": "./dist/phosphor/fill/*.svg.cjs",
      "types": "./dist/phosphor/fill/*.svg.d.ts"
    },
    "./phosphor/light/*.svg": {
      "import": "./dist/phosphor/light/*.svg.js",
      "require": "./dist/phosphor/light/*.svg.cjs",
      "types": "./dist/phosphor/light/*.svg.d.ts"
    },
    "./phosphor/regular/*.svg": {
      "import": "./dist/phosphor/regular/*.svg.js",
      "require": "./dist/phosphor/regular/*.svg.cjs",
      "types": "./dist/phosphor/regular/*.svg.d.ts"
    },
    "./phosphor/thin/*.svg": {
      "import": "./dist/phosphor/thin/*.svg.js",
      "require": "./dist/phosphor/thin/*.svg.cjs",
      "types": "./dist/phosphor/thin/*.svg.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bun run tools/generate.ts",
    "clean": "rm -rf dist"
  },
  "sideEffects": false,
  "keywords": [
    "icons",
    "svg",
    "phosphor",
    "cisco"
  ],
  "author": {
    "name": "Jordan Clemens",
    "email": "jorcleme@cisco.com",
    "url": "https://jordan-clemens-dev.netlify.app"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.1.0",
    "chalk": "^5.6.2",
    "fs-extra": "^11.3.3",
    "typescript": "^5.9.3"
  }
}
