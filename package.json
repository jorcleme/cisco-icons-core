{
  "name": "@jorcleme/cisco-icons-core",
  "version": "0.1.0",
  "description": "Icon catalog and assets for Cisco Icons (Phosphor + Cisco branded)",
  "license": "MIT",
  "author": {
    "name": "Jordan Clemens",
    "email": "jorcleme@cisco.com",
    "url": "https://jordan-clemens-dev.netlify.app"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jorcleme/cisco-icons-core.git"
  },
  "homepage": "https://github.com/jorcleme/cisco-icons-core#readme",
  "bugs": {
    "url": "https://github.com/jorcleme/cisco-icons-core/issues"
  },
  "keywords": [
    "icons",
    "svg",
    "phosphor",
    "cisco"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./assets/phosphor/thin/*.svg": "./assets/phosphor/thin/*.svg",
    "./assets/phosphor/light/*.svg": "./assets/phosphor/light/*.svg",
    "./assets/phosphor/regular/*.svg": "./assets/phosphor/regular/*.svg",
    "./assets/phosphor/bold/*.svg": "./assets/phosphor/bold/*.svg",
    "./assets/phosphor/fill/*.svg": "./assets/phosphor/fill/*.svg",
    "./assets/phosphor/duotone/*.svg": "./assets/phosphor/duotone/*.svg",
    "./assets/cisco/regular/*.svg": "./assets/cisco/regular/*.svg",
    "./phosphor/thin/*.svg": "./assets/phosphor/thin/*.svg",
    "./phosphor/light/*.svg": "./assets/phosphor/light/*.svg",
    "./phosphor/regular/*.svg": "./assets/phosphor/regular/*.svg",
    "./phosphor/bold/*.svg": "./assets/phosphor/bold/*.svg",
    "./phosphor/fill/*.svg": "./assets/phosphor/fill/*.svg",
    "./phosphor/duotone/*.svg": "./assets/phosphor/duotone/*.svg",
    "./cisco/regular/*.svg": "./assets/cisco/regular/*.svg"
  },
  "files": [
    "dist",
    "assets"
  ],
  "sideEffects": false,
  "scripts": {
    "clean": "rm -rf dist assets",
    "collate": "bun run scripts/collate.ts",
    "catalog": "bun run scripts/catalog.ts",
    "build:assets": "bun run collate && bun run catalog",
    "build:lib": "vite build && tsc --emitDeclarationOnly",
    "build": "bun run clean && bun run build:assets && bun run build:lib",
    "prepublishOnly": "bun run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "npm run build:assets && cp -r assets docs/public/assets && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "devDependencies": {
    "@types/bun": "^1.3.8",
    "@types/node": "^22.0.0",
    "chalk": "^5.4.1",
    "typescript": "^5.7.3",
    "vite": "^8.0.0",
    "vitepress": "^1.6.4",
    "vue": "^3.5.27"
  }
}
